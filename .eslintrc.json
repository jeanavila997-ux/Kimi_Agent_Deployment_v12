{
  "env": {
    "browser": true,
    "es2022": true,
    "serviceworker": true
  },
  "extends": "eslint:recommended",
  "ignorePatterns": [
    "js/vendor/**/*.js",
    "**/vendor/*.js"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "off",
    "no-console": "off"
  }
}
